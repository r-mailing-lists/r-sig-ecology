Subject: [R-sig-eco] Predicting lm including spatial filtering
Message-ID: <AM4PR0202MB29317B9121C90799069EC846ECB50@AM4PR0202MB2931.eurprd02.prod.outlook.com>

Dear all,

I included in my linear model spatial filtering, because the data is spatial autocorrelated. Now I want to plot the predicted values. However when I plot the predicted values they show not a linear prediction as expected. I think that it has to do with the fact that the new matrix with median values, is not taken into account in the prediction. Does anyone know how to go around this?

please find below a reproducable example. Looking forward to you opinions.

Best regards,

Maarten de Groot


library(spdep)

library(adespatial)

library(MASS)

library(ade4)

library(spatialreg)

data(meuse)

summary(meuse)

# Create SpatialPointsDataFrame

coordinates(meuse) <- ~ x + y

SpatPoints<-meuse[,1]

# Reverse to normal dataframe

meuse<-data.frame(meuse)

# Create Neighbour list:

nb<-tri2nb(SpatPoints, row.names = NULL)

# Create Spatial weights for neighbours lists:

listw<-nb2listw(neighbours=nb, glist=NULL, style="W", zero.policy=NULL)

can.be.simmed(listw)

# Model Moran's Eigenvectors

# LM

EV1<-SpatialFiltering(formula=cadmium ~ elev + dist  + factor(soil),

       data=meuse, nb=nb, style="W", ExactEV=TRUE, verbose=T)

# Create ME covariate to be added to GLM:

EV_fit1<-fitted(EV1)

class(EV_fit1)

# Add ME covariate to GLM:

Model_example<-lm(cadmium ~ elev + dist  + factor(soil)+EV_fit1,

                   data=meuse, family = gaussian)

summary(Model_example)

step(Model_example)

Model_example_fin<-glm(formula = cadmium ~ elev + dist + factor(soil) + EV_fit1,

                       family = gaussian, data = meuse)

summary(Model_example_fin)

#--------- preparation of data for the figure

medianEV_fit1<-EV_fit1

medianEV_fit1[] <- median(medianEV_fit1)

summary(medianEV_fit1)

otherdata <- data.frame(elev=meuse$elev,

                      dist=median(meuse$dist),

                      soil=meuse$soil,

                      EV_fit1=medianEV_fit1)

summary(otherdata)

meuse$predmod1<-predict(Model_example_fin,newdata=otherdata,type="response")

summary(meuse)

#----- graph ----------------------------------------

library(ggplot2)

ggplot(meuse,aes(x=elev,y=cadmium, col=soil))+geom_point()+geom_line(aes(y=predmod))

#-----without spatial filtering---------

Model_example_fin_without<-glm(formula = cadmium ~ elev + dist + factor(soil),

                       family = gaussian, data = meuse)

summary(Model_example_fin_without)

#--------- preparation of data for the figure

newdata <- data.frame(elev=meuse$elev,

                      dist=median(meuse$dist),

                      soil=meuse$soil)

summary(newdata)

meuse$predmodwithout<-predict(Model_example_fin_without,newdata=newdata,type="response")

#----- graph ----------------------------------------

library(ggplot2)

ggplot(meuse,aes(x=elev,y=cadmium, col=soil))+geom_point()+geom_line(aes(y=predmodwithout))



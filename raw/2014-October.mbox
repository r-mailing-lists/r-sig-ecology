hist(log(abund.null[,20]))
par(op)




### independent swap model
abund.null <- randomizeMatrix(abund, null.model = "independentswap")

# community matrix
pal <- colorRampPalette(c("blue4", "cyan", "yellow","red1"), bias=3)

##########################################
require(meta)

n <- 40

r <- c(0.590, 0.660, 0.330, -0.840, 0.840, 0.050, 0.020, 0.040, 0.100,
0.050, 0.390, 0.500, 0.610, -0.140, 0.330, 0.130, -0.150, 0.880, 0.780,

text(1.6, 0.6, "X2")
text(-0.6, 0.6, "X1")
text(-0.1, -1.5, "X3")

plot(mod)
#  In Windows, after the following text function then click at the
#  three desired locations of the plot and then right-click stop
text(locator(), c("X1","X2","X3"), cex=1.2)



 > head(captures_df)
 ??????? Date Captures Week_num
1 2021-01-06??????? 2?????? 01
2 2021-01-07??????? 2?????? 01
3 2021-01-08??????? 6?????? 01
4 2021-01-09??????? 3?????? 01
5 2021-01-12??????? 9?????? 02
6 2021-01-13??????? 8?????? 02


# Now we can group_by the Week_sum column and sum captures for each week:

captures_weekly = captures_df %>%

 ??? ??? group_by(Week_num) %>%

 ??? ??? summarize(Weekly_sum = sum(Captures))
captures_weekly
# A tibble: 9 x 2
 ? Week_num Weekly_sum
 ? <chr>???????? <int>

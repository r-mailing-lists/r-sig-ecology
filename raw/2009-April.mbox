output out=ACiOUT parms=Vcmax J Rd predicted=Ahat student=student;
run;
ods listing;
data temporary;
set status;
where(_TYPE_ ne'GRID' and _TYPE_ ne'COVB');
run;
data estimates;
merge estimates temporary(keep=factor1 factor2 days _status_ _iter_);
by factor1 factor2 days;
run;
?

